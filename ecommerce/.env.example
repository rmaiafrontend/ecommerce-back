# URL completa do MongoDB (substitua usuário e senha pelos seus)
MONGO_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority

# Chave secreta para assinatura dos tokens JWT (use um valor longo e aleatório)
JWT_SECRET=sua_chave_secreta_longa_e_aleatoria_aqui
